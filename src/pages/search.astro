---
import Html from "components/layout/html.astro";
import Nav from "components/layout/navbar.astro";
---

<Html title="Search" description="Search the blog">
  <Nav />
  <main class="main-container">
    <div class="article-container">
      <h1 class="search-header">블로그 검색</h1>
      <div class="pt-4" id="search"></div>
    </div>
  </main>
</Html>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

<script is:inline>
  // url → meta 맵 (processResult 콜백에서 채워지고 MutationObserver에서 사용)
  const _metaMap = new Map();

  // 결과 inner에 date/kind를 article-meta 스타일로 삽입 + 발췌 중복 제거
  function _doInjectMeta(inner, titleEl, meta) {
    if (inner.dataset.metaInjected === "1") return;
    inner.dataset.metaInjected = "1";

    const date = meta.date;
    const kind = meta.kind;

    // ── meta 줄 삽입 ──────────────────────────────────────────────
    if ((date || kind) && !inner.querySelector(".pagefind-result-meta")) {
      const metaEl = document.createElement("p");
      metaEl.className = "pagefind-result-meta";

      if (kind) {
        const kindSpan = document.createElement("span");
        kindSpan.className =
          kind === "article"
            ? "pagefind-meta-kind pagefind-meta-article"
            : "pagefind-meta-kind pagefind-meta-note";
        kindSpan.textContent = kind.charAt(0).toUpperCase() + kind.slice(1);
        metaEl.appendChild(kindSpan);
      }

      if (date) {
        const dateSpan = document.createElement("span");
        dateSpan.className = "pagefind-meta-date";
        dateSpan.textContent = date;
        metaEl.appendChild(dateSpan);
      }

      titleEl.insertAdjacentElement("afterend", metaEl);
    }

    // ── 발췌문 앞쪽의 제목 반복 제거 ───────────────────────────────
    // pagefind가 제목(h1)에서 검색어를 찾으면 발췌문에 제목 텍스트가 그대로 표시됨
    // 제목 뒤에 본문 조각이 붙은 경우에는 제목 부분만 잘라내고 본문은 유지함
    const excerptEl = inner.querySelector(".pagefind-ui__result-excerpt");
    const anchor = titleEl.querySelector("a");
    if (excerptEl && anchor) {
      const normalizeText = (value) => value.trim().replace(/\s+/g, " ");
      const trimExcerptMarks = (value) =>
        value.replace(/^[\s.…·]+|[\s.…·]+$/g, "").replace(/\s+/g, " ");
      const hasSearchableText = (value) => /[\p{L}\p{N}]/u.test(value);
      const removeLeadingText = (element, count) => {
        let remaining = count;
        const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT);
        while (remaining > 0) {
          const node = walker.nextNode();
          if (!node) break;

          if (node.nodeValue.length <= remaining) {
            remaining -= node.nodeValue.length;
            node.nodeValue = "";
          } else {
            node.nodeValue = node.nodeValue.slice(remaining);
            remaining = 0;
          }
        }
      };
      const trimLeadingTextNode = (element) => {
        const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT);
        let node = walker.nextNode();
        while (node) {
          const trimmed = node.nodeValue.replace(/^[\s.…·.。]+/, "");
          if (trimmed !== node.nodeValue) {
            node.nodeValue = trimmed;
          }

          if (node.nodeValue.length > 0) {
            break;
          }

          node = walker.nextNode();
        }
      };
      const getLeadingTitleMatchLength = (excerpt, title) => {
        const leadingMarksLength = excerpt.match(/^[\s.…·]*/)?.[0]?.length ?? 0;
        const candidate = excerpt.slice(leadingMarksLength);

        for (let length = Math.min(candidate.length, title.length); length >= 10; length--) {
          const leadingText = normalizeText(candidate.slice(0, length));
          if (leadingText.length >= 10 && title.includes(leadingText)) {
            return leadingMarksLength + length;
          }
        }

        return 0;
      };
      const titleText = normalizeText(anchor.textContent);
      const excerptText = normalizeText(excerptEl.textContent);
      // 앞뒤 말줄임표/공백 제거한 발췌문 (pagefind가 중간 매칭 시 "...텍스트..." 형태로 잘라냄)
      const cleanExcerpt = trimExcerptMarks(excerptText);
      // pagefind는 발췌문을 "제목 일부분. 본문 내용..." 형태로 생성함
      // → ". " 앞의 첫 문장만 잘라 제목에 포함되는지 비교
      const firstSentenceMatch = excerptEl.textContent.match(/^[\s.…·]*(.+?)(?:[.。](?:\s|$)|$)/s);
      const firstSentence = normalizeText(firstSentenceMatch?.[1] ?? cleanExcerpt);
      const leadingTitleMatchLength = getLeadingTitleMatchLength(excerptEl.textContent, titleText);

      if (titleText && leadingTitleMatchLength > 0) {
        removeLeadingText(excerptEl, leadingTitleMatchLength);
        trimLeadingTextNode(excerptEl);

        if (!hasSearchableText(excerptEl.textContent)) {
          excerptEl.style.display = "none";
        }
      } else if (titleText && firstSentence.length > 10 && titleText.includes(firstSentence)) {
        removeLeadingText(excerptEl, firstSentenceMatch?.[0]?.length ?? excerptEl.textContent.length);
        trimLeadingTextNode(excerptEl);

        if (!hasSearchableText(excerptEl.textContent)) {
          excerptEl.style.display = "none";
        }
      }
    }
  }

  // 현재 렌더링된 결과 목록을 순회하며 meta 삽입 시도
  function injectMetaIntoResults(container) {
    const inners = container.querySelectorAll(".pagefind-ui__result-inner");
    inners.forEach((inner) => {
      if (inner.dataset.metaInjected) return;

      const titleEl = inner.querySelector(".pagefind-ui__result-title");
      if (!titleEl) return;

      const anchor = titleEl.querySelector("a");
      if (!anchor) return;

      const href = anchor.getAttribute("href") || "";

      // processResult에서 이미 맵에 저장된 경우 즉시 삽입
      if (_metaMap.has(href)) {
        _doInjectMeta(inner, titleEl, _metaMap.get(href));
        return;
      }

      // 맵에 없으면 pending 표시 후 pagefind API로 직접 조회 (fallback)
      inner.dataset.metaInjected = "pending";
      if (window.__pagefind__) {
        window.__pagefind__
          .getByURL(href)
          .then((data) => {
            if (!data) { inner.dataset.metaInjected = "1"; return; }
            const meta = data.meta || {};
            _metaMap.set(href, meta);
            _doInjectMeta(inner, titleEl, meta);
          })
          .catch(() => {
            inner.dataset.metaInjected = "1";
          });
      } else {
        inner.dataset.metaInjected = "1";
      }
    });
  }

  function initPagefind() {
    const searchDiv = document.getElementById("search");
    if (!searchDiv) return;

    searchDiv.innerHTML = "";

    const scriptSrc = "/pagefind/pagefind-ui.js";

    const pagefindConfig = {
      element: "#search",
      showSubResults: false,
      showImages: false,
      pageSize: 20,
      translations: {
        placeholder: "검색어를 입력하세요...",
        zero_results: "[SEARCH_TERM]에 대한 결과가 없습니다.",
        one_result: "관련글 : [COUNT] 건",
        many_results: "관련글 : [COUNT] 건",
        clear_search: "clear",
      },
      processResult: function (result) {
        result.url = result.url.replace(".html", "");
        // meta를 맵에 미리 저장 → MutationObserver에서 즉시 사용 가능
        if (result.meta) {
          _metaMap.set(result.url, result.meta);
        }
        if (result.sub_results) {
          result.sub_results.forEach((sub) => {
            sub.url = sub.url.replace(".html", "");
          });
        }
        return result;
      },
    };

    function setupInputHandler() {
      setTimeout(() => {
        const input = searchDiv.querySelector("input");
        if (input) {
          input.focus();

          const urlParams = new URLSearchParams(window.location.search);
          const query = urlParams.get("q");
          if (query) {
            input.value = query;
            input.dispatchEvent(new Event("input", { bubbles: true }));
          }

          input.addEventListener("input", (e) => {
            const term = e.target.value;
            const url = new URL(window.location);
            if (term) {
              url.searchParams.set("q", term);
            } else {
              url.searchParams.delete("q");
            }
            history.replaceState(history.state, "", url);
          });
        }
      }, 100);
    }

    // MutationObserver로 결과 렌더링 감지 후 meta 삽입
    const observer = new MutationObserver(() => {
      injectMetaIntoResults(searchDiv);
    });
    observer.observe(searchDiv, { childList: true, subtree: true });

    if (typeof PagefindUI !== "undefined") {
      new PagefindUI(pagefindConfig);
      setupInputHandler();
    } else {
      const script = document.createElement("script");
      script.src = scriptSrc;
      script.onload = () => {
        new PagefindUI(pagefindConfig);
        setupInputHandler();
      };
      document.head.appendChild(script);
    }
  }

  window.addEventListener("DOMContentLoaded", initPagefind);
  document.addEventListener("astro:page-load", initPagefind);
</script>

<style is:global>
  #search {
    --pagefind-ui-scale: 1;
    --pagefind-ui-text: var(--color-text-primary);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans);
    --pagefind-search-height: 48px;

    .pagefind-ui__message {
      font-weight: 400;
    }

    .pagefind-ui__form::before {
      top: calc((var(--pagefind-search-height) - (18px * var(--pagefind-ui-scale))) / 2);
      left: calc(16px * var(--pagefind-ui-scale));
    }

    .pagefind-ui__search-input {
      height: var(--pagefind-search-height);
      padding-left: calc(44px * var(--pagefind-ui-scale));
      font-size: 1.1em;
    }

    input {
      font-weight: 500;
    }

    .pagefind-ui__search-clear {
      background-color: transparent;
      display: flex;
      align-items: center;
      font-size: 0.92em;
      height: calc(var(--pagefind-search-height) - (6px * var(--pagefind-ui-scale)));
      line-height: 1;
    }

    .pagefind-ui__result {
      padding: 10px 0;
    }

    .pagefind-ui__result-title {
      font-size: var(--base-font-size);
      margin: 0;
    }

    .pagefind-ui__result-link {
      font-size: 1.2em;
      font-weight: 700;
      line-height: 1.2;
      text-underline-offset: 4px;
      text-decoration-thickness: 2px;
    }

    @media (min-width: 768px) {
      .pagefind-ui__result-link {
        font-size: 1.3em;
      }
    }

    .pagefind-ui__result-excerpt {
      font-size: var(--base-font-size);
      margin-top: var(--spacing-4, 1rem);
    }

    /* pagefind 기본 태그(Date: / Kind:) 숨김 */
    .pagefind-ui__result-tags {
      display: none;
    }

    .pagefind-ui mark {
      background-color: transparent;
      color: var(--mark-text-color);
      font-weight: 500;
    }
  }

  /* 삽입된 article-meta 스타일 — CSS 중첩 밖에서 명시적으로 작성해 특이성 확보 */
  #search .pagefind-result-meta {
    display: flex;
    gap: var(--spacing-2, 0.5rem);
    align-items: center;
    margin: 1px 0 0 var(--spacing-1, 0.25rem);
    font-size: 0.84em;
    color: var(--color-text-muted);
  }

  #search .pagefind-result-meta .pagefind-meta-date {
    color: var(--color-text-muted);
  }

  #search .pagefind-result-meta .pagefind-meta-article,
  #search .pagefind-result-meta .pagefind-meta-note {
    color: var(--color-text-muted);
  }
</style>
