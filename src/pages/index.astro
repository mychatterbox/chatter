---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import FeedItem from "components/content/feed-item.astro";
import Html from "components/layout/html.astro";
import Nav from "components/layout/navbar.astro";
import Pagination from "components/features/Pagination.astro";
import { PAGE_SIZE } from "config/pagination";

const blogPosts = await getCollection("blog");

let draftPosts: CollectionEntry<"draft">[] = [];
if (import.meta.env.DEV) {
  try {
    draftPosts = await getCollection("draft");
  } catch {
    console.warn("Draft collection is empty or does not exist");
  }
}

const allPosts = [...blogPosts, ...draftPosts];
allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE);

const apiUrl =
  import.meta.env.PUBLIC_YCC_API_URL ||
  "https://yangchun-comment-server.chatterer.workers.dev";
---

<Html title="mychatterbox" description="Astro 프레임워크를 이용해서 만들어진 블로그입니다. 여러가지 소소한 팁과 정보를 공유합니다.">
  <Nav />

  <main class="main-container">
  <h1 class="visually-hidden">mychatterbox 글 목록</h1>
  <div class="landing-content">
    <ul class="feed-list">
      {posts.map((entry) => (<FeedItem entry={entry} />))}
    </ul>
    
    <Pagination 
      currentPage={1}
      totalPages={totalPages}
      baseUrl="/"
    />
  </div>
  </main>
</Html>

<script define:vars={{ apiUrl }}>
  const updateCommentCounts = async () => {
    const wrappers = document.querySelectorAll(".comment-count-wrapper");
    
    // 10개의 요청을 병렬로 처리하여 속도를 높임
    await Promise.all(
      Array.from(wrappers).map(async (wrapper) => {
        const postId = wrapper.getAttribute("data-post-id");
        if (!postId) return;

        try {
          const response = await fetch(`${apiUrl}/api/comments?post=${postId}`);
          if (response.ok) {
            const data = await response.json();
            const count = data.comments.length;
            if (count > 0) {
              const countEl = wrapper.querySelector(".comment-count-value");
              if (countEl) countEl.textContent = count.toString();
              wrapper.style.display = "inline-flex";
            }
          }
        } catch (err) {
          console.error(`Failed to fetch count for ${postId}:`, err);
        }
      })
    );
  };

  // Astro View Transitions 대응
  document.addEventListener("astro:page-load", updateCommentCounts);
</script>