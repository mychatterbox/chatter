<div id="search-modal-backdrop" class="search-modal-backdrop hidden">
  <div class="search-modal-content">
    <div class="pagefind-component-search">
      <div
        id="pf-custom-input"
        contenteditable="plaintext-only"
        role="textbox"
        class="pf-custom-input"
        data-placeholder="search..."
      >
      </div>
      <div
        id="pf-results-count"
        class="pf-results-count"
        style="display: none;"
      >
      </div>
      <div id="pf-custom-results" class="pf-custom-results"></div>
    </div>
  </div>
</div>

<script is:inline>
const PF_PAGE_SIZE = 20;

// 상태를 객체로 묶어 관리 (전역 변수 오염 방지)
let state = {
  activeIndex: -1,
  pagefindModule: null,
  currentSearchId: 0,
  allResults: [],
  loadedCount: 0,
  isLoading: false,
  sentinel: null,
  io: null,
  lastQuery: "",
  searchDebounce: null,
};

const SENTENCE_REGEX = /^(.+?)(?:[.。](?:\s|$)|$)/s;

function cleanExcerptTitle(excerptHtml, titleText) {
  if (!excerptHtml || !titleText) return excerptHtml;

  const normalize = (str) => str.trim().replace(/\s+/g, " ");
  const normalizedTitle = normalize(titleText);

  const tempDiv = document.createElement("div");
  tempDiv.innerHTML = excerptHtml;
  const pureExcerptText = normalize(tempDiv.textContent);

  let matchText = "";
  if (pureExcerptText.includes(normalizedTitle)) {
    matchText = normalizedTitle;
  } else {
    for (let i = 0; i < normalizedTitle.length - 6; i++) {
      const chunk = normalizedTitle.slice(i);
      if (pureExcerptText.startsWith(chunk)) {
        matchText = chunk;
        break;
      }
    }
  }

  if (matchText) {
    let html = excerptHtml.trim();
    let charCount = 0,
      cutIndex = 0,
      inTag = false;

    for (let i = 0; i < html.length; i++) {
      if (html[i] === "<") {
        inTag = true;
        continue;
      }
      if (html[i] === ">") {
        inTag = false;
        continue;
      }
      if (!inTag) {
        charCount++;
        if (charCount >= matchText.length) {
          cutIndex = i + 1;
          break;
        }
      }
    }

    return html.slice(cutIndex).replace(/^[\s.…·。/,-]+/, "");
  }

  const firstSentenceMatch = pureExcerptText.match(SENTENCE_REGEX);
  const firstSentence = firstSentenceMatch
    ? normalize(firstSentenceMatch[1])
    : "";

  if (firstSentence.length > 5 && normalizedTitle.includes(firstSentence)) {
    const raw = firstSentenceMatch[0];
    const escaped = raw.replace(/[-\/\\^$*+?.()|[\]{}]/g, "\\$&");
    return excerptHtml
      .replace(new RegExp("^[\\s.…·]*" + escaped, "s"), "")
      .replace(/^[\s.…·。/,-]+/, "");
  }

  return excerptHtml;
}

function createResultElement(
  mainSub,
  title,
  url,
  closeModal,
  isHeaderOnly = false,
  meta = {}
) {
  const finalUrl = (url || "").replace(/\.html$/, "");

  const tempDiv = document.createElement("div");
  tempDiv.innerHTML = mainSub.excerpt || "";
  let excerptHtml = tempDiv.innerHTML.trim();

  const dateStr = meta.date ? `Article ${meta.date}` : "";

  let tagStr = "";
  if (meta.tags) {
    tagStr = meta.tags
      .split(/,\s*|#/)
      .map((t) => t.trim())
      .filter((t) => t.length > 0)
      .map(
        (t) => `
      <span class="link-tag">
        <span class="tag-hash">#</span>${t}
      </span>`
      )
      .join(" ");
  }

  const metaHtml =
    dateStr || tagStr
      ? `
  <div class="pf-result-meta" style="display: flex; gap: 8px; align-items: center; margin-bottom: 4px;">
    ${dateStr ? `<span class="pf-result-date">${dateStr}</span>` : ""}
    ${tagStr ? `<span class="pf-result-tags">${tagStr}</span>` : ""}
  </div>`
      : "";

  const item = document.createElement("div");
  item.className = "pf-result-item";
  item.innerHTML = `
    <a href="${finalUrl}" class="pf-result-link" tabindex="-1">
      <div class="pf-result-title">${title}</div>
      ${metaHtml}
      ${!isHeaderOnly ? `<div class="pf-result-excerpt">${excerptHtml.substring(0, 150)}...</div>` : ""}
    </a>
  `;
  item.querySelector("a").addEventListener("click", closeModal);
  return item;
}

function createSubResultElement(sub, closeModal) {
  const item = document.createElement("div");
  item.className = "pf-result-item pf-sub-result-item";

  const cleanedExcerpt = cleanExcerptTitle(sub.excerpt || "", sub.title || "");

  item.innerHTML = `
    <a href="${sub.url}" class="pf-result-link" tabindex="-1">
      <div class="pf-sub-title"># ${sub.title}</div>
      <div class="pf-sub-excerpt">${cleanedExcerpt}</div>
    </a>
  `;
  item.querySelector("a").addEventListener("click", closeModal);
  return item;
}

async function renderNextBatch(searchId, resultsContainer, closeModal) {
  if (state.isLoading || state.loadedCount >= state.allResults.length) return;

  state.isLoading = true;
  const batch = state.allResults.slice(
    state.loadedCount,
    state.loadedCount + PF_PAGE_SIZE
  );

  try {
    const fragment = document.createDocumentFragment();

    for (let i = 0; i < batch.length; i++) {
      if (searchId !== state.currentSearchId) return;
      try {
        const data = await batch[i].data();
        const isHeaderMatch =
          data.sub_results.length > 0 &&
          data.sub_results[0].title !== data.meta.title;

        if (isHeaderMatch) {
          fragment.appendChild(
            createResultElement(
              data.sub_results[0],
              data.meta.title,
              data.url,
              closeModal,
              true,
              data.meta
            )
          );
          for (let j = 0; j < data.sub_results.length; j++) {
            fragment.appendChild(
              createSubResultElement(data.sub_results[j], closeModal)
            );
          }
        } else {
          fragment.appendChild(
            createResultElement(
              data.sub_results[0],
              data.meta.title,
              data.url,
              closeModal,
              false,
              data.meta
            )
          );
          for (let j = 1; j < data.sub_results.length; j++) {
            fragment.appendChild(
              createSubResultElement(data.sub_results[j], closeModal)
            );
          }
        }
      } catch (e) {
        console.error("Batch item error:", e);
      }
    }

    if (searchId !== state.currentSearchId) return;
    state.loadedCount += batch.length;

    if (state.sentinel?.parentNode === resultsContainer) {
      resultsContainer.insertBefore(fragment, state.sentinel);
    } else {
      resultsContainer.appendChild(fragment);
    }

    if (state.loadedCount >= state.allResults.length) {
      state.sentinel?.remove();
      state.sentinel = null;
      state.io?.disconnect();
      state.io = null;
    }
  } finally {
    state.isLoading = false;
  }
}

async function handleSearch(query, resultsContainer, closeModal) {
  const countEl = document.getElementById("pf-results-count");
  const searchId = ++state.currentSearchId;

  state.activeIndex = -1;
  state.io?.disconnect();
  state.io = null;
  state.sentinel?.remove();
  state.sentinel = null;
  state.allResults = [];
  state.loadedCount = 0;
  state.isLoading = false;

  if (!query) {
    resultsContainer.innerHTML = "";
    countEl.style.display = "none";
    countEl.innerText = "";
    return;
  }
  if (!state.pagefindModule) return;

  const search = await state.pagefindModule.search(query);
  if (searchId !== state.currentSearchId) return;

  resultsContainer.innerHTML = "";

  if (search.results.length === 0) {
    resultsContainer.innerHTML = `<div class="pf-no-results">"${query}" : 검색 결과가 없습니다.</div>`;
    countEl.style.display = "none";
    return;
  }

  state.allResults = search.results;
  countEl.innerText = `검색 결과 : ${state.allResults.length} 페이지`;
  countEl.style.display = "block";

  await renderNextBatch(searchId, resultsContainer, closeModal);

  if (state.allResults.length > PF_PAGE_SIZE) {
    state.sentinel = document.createElement("div");
    state.sentinel.className = "pf-sentinel";
    resultsContainer.appendChild(state.sentinel);
    initInfiniteScroll(resultsContainer, closeModal);
  }
}

function initInfiniteScroll(resultsContainer, closeModal) {
  const options = {
    root: resultsContainer.closest(".search-modal-content"),
    rootMargin: "200px",
    threshold: 0,
  };

  state.io = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !state.isLoading) {
      renderNextBatch(state.currentSearchId, resultsContainer, closeModal);
    }
  }, options);

  if (state.sentinel) {
    state.io.observe(state.sentinel);
  }
}

function initPagefindComponentModal() {
  const backdrop = document.getElementById("search-modal-backdrop");
  const input = document.getElementById("pf-custom-input");
  const resultsContainer = document.getElementById("pf-custom-results");
  if (!backdrop || !input || !resultsContainer) return;

  // astro:page-load 중복 초기화 방지
  if (backdrop.dataset.initialized) return;
  backdrop.dataset.initialized = "true";

  backdrop.addEventListener("click", (e) => {
    if (e.target === backdrop) closeModal();
  });

  window.openSearchModal = async function () {
    backdrop.classList.remove("hidden");

    if (!state.pagefindModule) {
      try {
        state.pagefindModule = await import("/pagefind/pagefind.js");
        state.pagefindModule.init();
      } catch (err) {
        console.error("Pagefind 로드 실패:", err);
      }
    }
    setTimeout(() => input.focus(), 50);
  };

  // ✅ 외부 스코프 변수 재사용, getElementById 중복 제거
  function closeModal() {
    backdrop.classList.add("hidden");

    // ✅ pending 타이머 정리
    clearTimeout(state.searchDebounce);

    input.textContent = "";
    resultsContainer.innerHTML = "";

    const countEl = document.getElementById("pf-results-count");
    countEl.style.display = "none";
    countEl.innerText = "";

    state.activeIndex = -1;
    state.lastQuery = "";
    state.allResults = [];
    state.loadedCount = 0;

    state.io?.disconnect();
    state.io = null;
    state.sentinel?.remove();
    state.sentinel = null;
  }

  input.addEventListener("input", () => {
    const rawQuery = input.textContent || "";

    if (rawQuery.trim() === "") {
      input.textContent = "";
    }

    const processedQuery = rawQuery
      .normalize("NFKC")
      .replace(/[<>]/g, "")
      .replace(/\s+/g, " ")
      .trim();

    if (processedQuery === state.lastQuery) return;

    // ✅ debounce 전에 즉시 업데이트하여 동기화 문제 방지
    state.lastQuery = processedQuery;

    // ✅ 이전 타이머를 항상 정리한 뒤 새로 등록
    clearTimeout(state.searchDebounce);
    state.searchDebounce = setTimeout(() => {
      handleSearch(processedQuery, resultsContainer, closeModal);
    }, 200);
  });

  input.addEventListener("paste", (e) => {
    e.preventDefault();
    const text = e.clipboardData.getData("text/plain");
    const selection = window.getSelection();
    if (!selection.rangeCount) return;
    selection.deleteFromDocument();
    selection.getRangeAt(0).insertNode(document.createTextNode(text));
    selection.collapseToEnd();
    input.dispatchEvent(new Event("input"));
  });

  input.addEventListener("keydown", (e) => {
    if (e.key === "Tab") {
      e.preventDefault();
      const links = [
        ...resultsContainer.querySelectorAll("a.pf-result-link"),
      ];
      if (links.length === 0) return;

      if (e.shiftKey) {
        state.activeIndex =
          state.activeIndex <= 0 ? links.length - 1 : state.activeIndex - 1;
      } else {
        state.activeIndex =
          state.activeIndex >= links.length - 1 ? 0 : state.activeIndex + 1;
      }

      updateVisualSelection(links);
    }

    if (backdrop.classList.contains("hidden")) return;

    if (["ArrowDown", "ArrowUp", "Enter"].includes(e.key)) {
      e.preventDefault();
    }

    const links = [...resultsContainer.querySelectorAll("a.pf-result-link")];

    if (e.key === "Enter") {
      if (state.activeIndex >= 0) links[state.activeIndex]?.click();
    } else if (e.key === "ArrowDown") {
      if (links.length === 0) return;
      state.activeIndex = Math.min(state.activeIndex + 1, links.length - 1);
      updateVisualSelection(links);
    } else if (e.key === "ArrowUp") {
      state.activeIndex = Math.max(state.activeIndex - 1, -1);
      updateVisualSelection(links);
    } else if (e.key === "Escape") {
      closeModal();
    }
  });

  function updateVisualSelection(links) {
    links.forEach((l, i) => {
      if (i === state.activeIndex) {
        l.parentElement.classList.add("selected");
        l.parentElement.scrollIntoView({ block: "nearest" });
      } else {
        l.parentElement.classList.remove("selected");
      }
    });

    if (state.activeIndex === -1) {
      input.focus();
    }
    if (
      state.activeIndex === links.length - 1 &&
      state.loadedCount < state.allResults.length
    ) {
      renderNextBatch(state.currentSearchId, resultsContainer, closeModal);
    }
  }
}

document.addEventListener("astro:page-load", initPagefindComponentModal);

</script>

<style is:global>
  .search-modal-backdrop.hidden {
    display: none !important;
  }

  .search-modal-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 99999;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: var(--spacing-12, 3rem);
    backdrop-filter: blur(1px);
  }

  .pf-custom-input:empty::before {
  content: attr(data-placeholder);
  color: var(--color-text-muted);
  pointer-events: none;
  }

  .search-modal-content {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    width: calc(100% - var(--spacing-4) * 2);
    max-width: var(--breakpoint-md);
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15);
    padding: var(--spacing-2) 0;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    display: flex;
    flex-direction: column;
    overscroll-behavior: contain;
  }

  .dark .search-modal-content {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
  }

  .pagefind-component-search {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .pf-custom-input {
    padding: 3px 16px;
    border-radius: 0.4rem;
    border: 2px solid var(--color-border);
    outline: none;
    margin: 0 var(--spacing-2);
    color: var(--color-text-heading);
  }

  .pf-custom-input:focus {
    border-color: var(--color-link-article);
  }

  .pf-custom-results {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    border: none;
    scroll-padding-block-end: var(--spacing-1);
    padding: 0 0 0 var(--spacing-2);
  }

  .pf-custom-results.pf-results-loading {
    opacity: 0.35;
    pointer-events: none;
  }

  .pf-sentinel {
    height: 20px;
    width: 100%;
    background-color: transparent;
    flex-shrink: 0;
  }

  .pf-result-item {
    padding: 0 4px 0 12px;
    cursor: pointer;
    background-color: var(--color-bg);
  }

  .pf-result-item:hover,
  .pf-result-item:focus-within,
  .pf-result-item.selected {
    background-color: var(--color-select-item-hover-bg);
  }

  .pf-result-item.selected {
    border-radius: 0.3rem;
  }

  .pf-result-link {
    display: block;
    text-decoration: none !important;
    outline: none;
  }

  /* 일반 결과 아이템 (서브 제외) */
  .pf-result-item:not(.pf-sub-result-item) {
    border-left: 3px solid var(--color-text-muted);
    margin-top: var(--spacing-8);
  }

  .pf-result-item:not(.pf-sub-result-item):first-child {
    margin-top: 0;
  }

  .pf-result-title {
    font-size: 1.15em;
    font-weight: 700;
    color: var(--color-text-heading);
    line-height: 1.5;
  }

  .pagefind-result-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-2, 0.5rem);
    font-size: 0.85em;
    margin-bottom: var(--spacing-2, 0.5rem);
    color: var(--color-text-muted);
  }

  .pf-meta-tag mark {
    background-color: transparent;
    color: var(--mark-text-color);
