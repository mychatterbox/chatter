    justify-content: center;
    align-items: flex-start;
    padding-top: var(--spacing-12, 3rem);
    backdrop-filter: blur(1px);
  }

  .search-modal-content {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    width: calc(100% - var(--spacing-4) * 2);
    max-width: var(--breakpoint-md);
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15);
    padding: var(--spacing-2) var(--spacing-2) var(--spacing-2) var(--spacing-2);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    display: flex;
    flex-direction: column;
     overscroll-behavior: contain;
  }

  .dark .search-modal-content {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
  }

  .pagefind-component-search {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .pf-custom-input {
    width: 100%;
    padding: 3px 16px;
    border-radius: 0.4rem;
    border: 2px solid var(--color-border);
    outline: none;
    /* margin-bottom: var(--spacing-2); */
  }

  .pf-custom-input:focus {
    border-color: var(--color-link-article);
  }

  .pf-custom-results {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    border: none;
    /* margin-top: var(--spacing-1); */
    scroll-padding-block-end: var(--spacing-1);
  }

  .pf-custom-results.pf-results-loading {
    opacity: 0.35;
    pointer-events: none;
  }

  .pf-sentinel {
    height: 20px;
    width: 100%;
    background-color: transparent;
    flex-shrink: 0;
  }

  .pf-result-item {
    padding: 12px;
    border-radius: 0.3rem;
    cursor: pointer;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
  }

  .pf-result-item:hover {
    background-color: var(--color-select-item-hover-bg);
  }

  .pf-result-link {
    display: block;
    text-decoration: none !important;
    outline: none;
  }

  .pf-result-item:focus-within {
    background-color: var(--color-select-item-hover-bg);
  }

  .pf-result-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-heading);
  }

  .pagefind-result-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-2, 0.5rem);
    font-size: 0.85rem;
    margin-bottom: var(--spacing-2, 0.5rem);
    color: var(--color-text-muted);
  }

  .pf-meta-tag mark {
    background-color: transparent;
    color: var(--mark-text-color);
    font-weight: 600;
    opacity: 1;
  }

  .pf-result-excerpt {
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .pf-result-excerpt mark {
    background-color: transparent;
    color: var(--mark-text-color);
    font-weight: 600;
  }

  .pf-no-results {
    padding: var(--spacing-4);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .pf-result-item.selected {
    background-color: var(--color-select-item-hover-bg);
    border-color: var(--color-link-article);
  }

  .pf-custom-input:empty::before {
    content: attr(data-placeholder);
    pointer-events: none;
  }
  
  .pf-results-count
  {
    margin-top: var(--spacing-1);
    font-size: 0.88em;
    color: var(--color-text-muted);
  }
</style>
